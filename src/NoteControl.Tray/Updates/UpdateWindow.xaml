<Window x:Class="NoteControl.Tray.Updates.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteControl — Update available"
        Width="600" Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Update available"
                       FontSize="20" FontWeight="SemiBold"/>
            <TextBlock x:Name="HeadlineText"
                       Foreground="#666"
                       Margin="0,4,0,0"
                       Text="A newer version of NoteControl has been published."/>
        </StackPanel>

        <Separator Grid.Row="1" Margin="0,0,0,8"/>

        <!-- Version line -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Installed:" Foreground="#555"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InstalledText" FontWeight="SemiBold"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Available:"  Foreground="#555" Margin="0,4,0,0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AvailableText" FontWeight="SemiBold" Margin="0,4,0,0"/>
        </Grid>

        <!-- Release notes label -->
        <TextBlock Grid.Row="3" Text="Release notes:"
                   Margin="0,12,0,4"
                   FontWeight="SemiBold"/>

        <!-- Release notes -->
        <Border Grid.Row="4"
                BorderBrush="#CCC"
                BorderThickness="1"
                Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8">
                <!--
    Plain TextBlock with TextWrapping. Markdown
    renders as raw text. The GitHub release body
    is markdown but a tray-side markdown renderer
    would be a separate dependency. The release
    page button at the bottom takes the user to
    the properly-rendered version on github.com.
-->
                <TextBlock x:Name="NotesText"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#333"/>
            </ScrollViewer>
        </Border>

        <!-- Progress (hidden by default) -->
        <StackPanel Grid.Row="5" Margin="0,12,0,0" x:Name="ProgressPanel" Visibility="Collapsed">
            <TextBlock x:Name="ProgressText" Foreground="#333"/>
            <ProgressBar x:Name="ProgressBar"
                         Height="14"
                         Margin="0,4,0,0"
                         Minimum="0" Maximum="100"
                         IsIndeterminate="False"/>
        </StackPanel>

        <!-- Buttons -->
        <DockPanel Grid.Row="6" Margin="0,16,0,0">
            <Button DockPanel.Dock="Left"
                    x:Name="ReleasePageButton"
                    Content="Open release page"
                    Width="160" Height="30"
                    Click="OpenReleasePage_Click"/>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="LaterButton"
                        Content="Later"
                        Width="90" Height="30"
                        Margin="0,0,8,0"
                        Click="Later_Click"/>
                <Button x:Name="InstallButton"
                        Content="Install now"
                        Width="120" Height="30"
                        FontWeight="SemiBold"
                        Click="Install_Click"
                        IsDefault="True"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
