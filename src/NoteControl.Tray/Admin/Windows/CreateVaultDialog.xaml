<Window x:Class="NoteControl.Tray.Admin.Windows.CreateVaultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create vault"
        Width="460" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Scope -->
            <RowDefinition Height="Auto"/>  <!-- 1: Owner -->
            <RowDefinition Height="Auto"/>  <!-- 2: Vault name -->
            <RowDefinition Height="Auto"/>  <!-- 3: Path preview -->
            <RowDefinition Height="Auto"/>  <!-- 4: Help text -->
            <RowDefinition Height="Auto"/>  <!-- 5: Error text -->
            <RowDefinition Height="*"/>     <!-- 6: spacer -->
            <RowDefinition Height="Auto"/>  <!-- 7: Buttons -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Scope:" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <RadioButton x:Name="PersonalRadio" Content="Personal" IsChecked="True"
                         VerticalAlignment="Center" Margin="0,0,16,0"
                         Checked="ScopeChanged"/>
            <RadioButton x:Name="SharedRadio" Content="Shared"
                         VerticalAlignment="Center"
                         Checked="ScopeChanged"/>
        </StackPanel>

        <!--
            Owner dropdown.

            Populated from the user list passed to the constructor. The
            currently-signed-in user is the default selection. Non-admin
            users see only themselves and the dropdown is effectively
            disabled (IsEnabled=false in code-behind based on the
            isAdmin flag), so they can't create vaults for someone else.
            For Personal scope, the chosen user shows up in the path
            (users/owner/name); for Shared scope the dropdown picks
            who owns the resulting vault for permission-management
            purposes (the path stays shared/name).
        -->
        <Label Grid.Row="1" Grid.Column="0" Content="Owner:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="OwnerCombo"
                  Margin="0,4" Padding="6,4"
                  SelectionChanged="OwnerCombo_SelectionChanged"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Vault name:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="NameBox"
                 Margin="0,4" Padding="6,4"
                 TextChanged="NameBox_TextChanged"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Path:" VerticalAlignment="Top" Margin="0,4,0,0"/>
        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PathPreview"
                   Margin="6,8,6,0"
                   Foreground="#444"
                   FontFamily="Consolas"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                   Margin="0,12,0,0"
                   Text="Personal vaults are visible only to the chosen owner. Shared vaults can be granted to other users."
                   Foreground="#666"
                   FontSize="11"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="5" Grid.ColumnSpan="2"
                   x:Name="ErrorText"
                   Margin="0,8,0,0"
                   Foreground="Crimson"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="Create" Width="80" Height="28"
                    IsDefault="True" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
