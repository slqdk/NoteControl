<Window x:Class="NoteControl.Tray.Admin.Windows.AddUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add user"
        Width="420" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Username:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="UsernameBox" Margin="0,4" Padding="6,4"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Email:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="EmailBox" Margin="0,4" Padding="6,4"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Password:" VerticalAlignment="Center"/>
        <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="PasswordBox" Margin="0,4" Padding="6,4"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Role:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="RoleBox" Margin="0,4" Padding="6,4"
                  SelectedIndex="0">
            <ComboBoxItem Content="user"/>
            <ComboBoxItem Content="admin"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                   Margin="0,8,0,0"
                   Text="Password must be at least 12 characters."
                   Foreground="#666"
                   FontSize="11"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="Add"    Width="80" Height="28"
                    IsDefault="True" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
