<Window x:Class="NoteControl.Tray.Admin.Windows.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteControl — Users"
        Width="900" Height="520"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left"
                       FontSize="16" FontWeight="SemiBold"
                       Text="Accounts"
                       VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right"
                    Content="Refresh"
                    Width="80" Height="26"
                    Click="RefreshButton_Click"/>
            <TextBlock x:Name="SignedInAsText"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="#555"/>
        </DockPanel>

        <!-- User list -->
        <DataGrid Grid.Row="1"
                  x:Name="UsersGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  SelectionChanged="UsersGrid_SelectionChanged"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Username"  Binding="{Binding Username}"   Width="140"/>
                <DataGridTextColumn Header="Email"     Binding="{Binding Email}"      Width="220"/>
                <DataGridTextColumn Header="Role"      Binding="{Binding Role}"       Width="80"/>
                <DataGridTextColumn Header="Status"    Binding="{Binding Status}"     Width="90"/>
                <DataGridTextColumn Header="Last login" Binding="{Binding LastLoginDisplay}" Width="160"/>
                <DataGridTextColumn Header="Created"   Binding="{Binding CreatedDisplay}"    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status / errors -->
        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Margin="0,8,0,0"
                   Foreground="#555"
                   TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,12,0,0">
            <Button Content="Add user…"        Width="100" Height="28" Margin="0,0,8,0"
                    Click="AddButton_Click"/>
            <Button Content="Edit…"            Width="80"  Height="28" Margin="0,0,8,0"
                    x:Name="EditButton"        Click="EditButton_Click"        IsEnabled="False"/>
            <Button Content="Reset password…"  Width="130" Height="28" Margin="0,0,8,0"
                    x:Name="ResetButton"       Click="ResetButton_Click"       IsEnabled="False"/>
            <Button Content="View sessions…"   Width="120" Height="28" Margin="0,0,8,0"
                    x:Name="SessionsButton"    Click="SessionsButton_Click"    IsEnabled="False"/>
            <Button Content="Disable"          Width="80"  Height="28" Margin="0,0,8,0"
                    x:Name="DisableButton"     Click="DisableButton_Click"     IsEnabled="False"/>
            <Button Content="Enable"           Width="80"  Height="28" Margin="0,0,8,0"
                    x:Name="EnableButton"      Click="EnableButton_Click"      IsEnabled="False"/>
            <Button Content="Delete"           Width="80"  Height="28" Margin="0,0,8,0"
                    x:Name="DeleteButton"      Click="DeleteButton_Click"      IsEnabled="False"
                    Foreground="Crimson"/>
            <Button Content="Sign out"         Width="80"  Height="28"
                    HorizontalAlignment="Right"
                    Click="SignOutButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
