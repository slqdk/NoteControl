<Window x:Class="NoteControl.Tray.Admin.Windows.VaultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteControl — Vaults"
        Width="980" Height="540"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left"
                       FontSize="16" FontWeight="SemiBold"
                       Text="Vaults"
                       VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right"
                    Content="Refresh"
                    Width="80" Height="26"
                    Click="RefreshButton_Click"/>

            <CheckBox DockPanel.Dock="Right"
                      x:Name="ShowAllCheckbox"
                      Content="Show all vaults"
                      VerticalAlignment="Center"
                      Margin="0,0,16,0"
                      Visibility="Collapsed"
                      Checked="ShowAllCheckbox_Changed"
                      Unchecked="ShowAllCheckbox_Changed"/>

            <TextBlock x:Name="SignedInAsText"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="#555"/>
        </DockPanel>

        <DataGrid Grid.Row="1"
                  x:Name="VaultsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  SelectionChanged="VaultsGrid_SelectionChanged"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Path"   Binding="{Binding Path}"          Width="280"/>
                <DataGridTextColumn Header="Name"   Binding="{Binding Name}"          Width="160"/>
                <DataGridTextColumn Header="Scope"  Binding="{Binding Scope}"         Width="80"/>
                <DataGridTextColumn Header="Owner"  Binding="{Binding OwnerUsername}" Width="120"/>
                <DataGridTextColumn Header="My role" Binding="{Binding MyRole}"       Width="90"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedDisplay}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Margin="0,8,0,0"
                   Foreground="#555"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Create vault…" Width="110" Height="28" Margin="0,0,8,0"
                    Click="CreateButton_Click"/>
            <Button Content="Register…"     Width="90"  Height="28" Margin="0,0,8,0"
                    x:Name="RegisterButton"
                    Click="RegisterButton_Click"
                    Visibility="Collapsed"
                    ToolTip="Adopt an existing on-disk folder as a vault. Admin only."/>
            <Button Content="Members…"      Width="100" Height="28" Margin="0,0,8,0"
                    x:Name="MembersButton"  Click="MembersButton_Click"  IsEnabled="False"/>
            <Button Content="Share…"        Width="80"  Height="28" Margin="0,0,8,0"
                    x:Name="ShareButton"    Click="ShareButton_Click"    IsEnabled="False"/>
            <Button Content="Open folder"   Width="100" Height="28" Margin="0,0,8,0"
                    x:Name="OpenFolderButton"
                    Click="OpenFolderButton_Click"
                    IsEnabled="False"
                    ToolTip="Open this vault's folder in Windows Explorer"/>
            <Button Content="Delete"        Width="80"  Height="28" Margin="0,0,8,0"
                    x:Name="DeleteButton"   Click="DeleteButton_Click"   IsEnabled="False"
                    Foreground="Crimson"/>
            <Button Content="Close"         Width="80"  Height="28"
                    HorizontalAlignment="Right"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
