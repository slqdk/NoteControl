<Window x:Class="NoteControl.Tray.Admin.Windows.VaultMembersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vault members"
        Width="700" Height="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="HeaderText"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1"
                  x:Name="MembersGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  SelectionChanged="MembersGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}"      Width="180"/>
                <DataGridTextColumn Header="Role"     Binding="{Binding Role}"          Width="100"/>
                <DataGridTextColumn Header="Granted"  Binding="{Binding GrantedDisplay}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Margin="0,8,0,0"
                   Foreground="#555"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Revoke access" Width="120" Height="28" Margin="0,0,8,0"
                    x:Name="RevokeButton" IsEnabled="False"
                    Click="RevokeButton_Click"
                    Foreground="Crimson"/>
            <Button Content="Refresh" Width="80" Height="28"
                    Click="RefreshButton_Click"/>
            <Button Content="Close" Width="80" Height="28"
                    HorizontalAlignment="Right"
                    Margin="20,0,0,0"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
