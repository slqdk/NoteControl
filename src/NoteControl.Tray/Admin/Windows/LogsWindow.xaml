<Window x:Class="NoteControl.Tray.Admin.Windows.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteControl — Logs"
        Width="980" Height="640"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left"
                       FontSize="16" FontWeight="SemiBold"
                       Text="Logs"
                       VerticalAlignment="Center"/>
            <CheckBox DockPanel.Dock="Right" x:Name="AutoRefreshBox"
                      Content="Auto-refresh (5s)"
                      VerticalAlignment="Center"
                      Click="AutoRefreshBox_Click"/>
            <TextBlock x:Name="LogPathText"
                       Foreground="#666"
                       VerticalAlignment="Center" Margin="12,0,12,0"
                       TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- Tabs -->
        <TabControl Grid.Row="1" x:Name="Tabs" SelectionChanged="Tabs_SelectionChanged">

            <!-- ============== Audit ============== -->
            <TabItem Header="Audit (user actions)">
                <DockPanel Margin="8">
                    <!-- Audit filters -->
                    <Border DockPanel.Dock="Top" Padding="8" Background="#F5F5F5"
                            BorderBrush="#DDD" BorderThickness="1" CornerRadius="3"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="Since (UTC):" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="AuditSinceBox" Padding="6,4" Margin="4,0,8,0"
                                     ToolTip="Optional. ISO format e.g. 2026-04-30T00:00:00Z. Leave blank for no lower bound."/>

                            <Label Grid.Column="2" Content="Event type:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="3" x:Name="AuditEventTypeBox"
                                      Margin="4,0,8,0" Padding="6,4"
                                      IsEditable="False"
                                      ToolTip="Select an event type or '(any)' for all."/>

                            <Label Grid.Column="4" Content="Limit:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="5" x:Name="AuditLimitBox" Padding="6,4" Margin="4,0,8,0"
                                     Text="200"
                                     ToolTip="Max rows to fetch (1-200)."/>

                            <Button Grid.Column="6" Content="Refresh" Width="80" Height="26"
                                    Click="AuditRefreshButton_Click"/>
                        </Grid>
                    </Border>

                    <!-- Audit grid -->
                    <DataGrid x:Name="AuditGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              FontFamily="Segoe UI"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time (local)" Binding="{Binding TimestampDisplay}" Width="160"/>
                            <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="200"/>
                            <DataGridTextColumn Header="User" Binding="{Binding UserDisplay}" Width="140"/>
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120"/>
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ============== Server log ============== -->
            <TabItem Header="Server log (Serilog)">
                <DockPanel Margin="8">
                    <!-- Filters -->
                    <Border DockPanel.Dock="Top" Padding="8" Background="#F5F5F5"
                            BorderBrush="#DDD" BorderThickness="1" CornerRadius="3"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="Min level:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="LogLevelBox"
                                      Margin="4,0,8,0" Padding="6,4"
                                      SelectionChanged="LogFilterChanged">
                                <ComboBoxItem Content="Verbose"/>
                                <ComboBoxItem Content="Debug"/>
                                <ComboBoxItem Content="Information" IsSelected="True"/>
                                <ComboBoxItem Content="Warning"/>
                                <ComboBoxItem Content="Error"/>
                                <ComboBoxItem Content="Fatal"/>
                            </ComboBox>

                            <Label Grid.Column="2" Content="Contains:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" x:Name="LogContainsBox" Padding="6,4" Margin="4,0,8,0"
                                     TextChanged="LogFilterChanged"
                                     ToolTip="Free-text substring filter (case-insensitive)."/>

                            <Label Grid.Column="4" Content="Lines:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="5" x:Name="LogLinesBox" Padding="6,4" Margin="4,0,8,0"
                                     Text="500"
                                     ToolTip="Max lines to fetch (1-5000)."/>

                            <Button Grid.Column="6" Content="Refresh" Width="80" Height="26"
                                    Click="LogRefreshButton_Click"/>
                        </Grid>
                    </Border>

                    <!-- Log grid -->
                    <DataGrid x:Name="LogGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              FontFamily="Cascadia Mono, Consolas, monospace"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time (local)" Binding="{Binding TimestampDisplay}" Width="180"/>
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="100"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- Status -->
        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Margin="0,8,0,0"
                   Foreground="#555"
                   TextWrapping="Wrap"/>

        <!-- Footer -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right"
                    Content="Close" Width="80" Height="28"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </DockPanel>
    </Grid>
</Window>
