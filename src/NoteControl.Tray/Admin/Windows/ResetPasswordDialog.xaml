<Window x:Class="NoteControl.Tray.Admin.Windows.ResetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset password"
        Width="420" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
                   x:Name="HeaderText"
                   TextWrapping="Wrap"/>

        <Label Grid.Row="1" Grid.Column="0" Content="New password:" VerticalAlignment="Center"/>
        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="PasswordBox" Margin="0,4" Padding="6,4"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Confirm:" VerticalAlignment="Center"/>
        <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="ConfirmBox" Margin="0,4" Padding="6,4"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                   Margin="0,8,0,0"
                   Text="Setting a new password will revoke all of this user's existing sessions."
                   Foreground="#666"
                   FontSize="11"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="Set password" Width="100" Height="28"
                    IsDefault="True" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
