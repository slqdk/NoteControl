<Window x:Class="NoteControl.Tray.Admin.Windows.SessionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Active sessions"
        Width="800" Height="420"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="HeaderText"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1"
                  x:Name="SessionsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Created"      Binding="{Binding CreatedDisplay}"   Width="140"/>
                <DataGridTextColumn Header="Last active"  Binding="{Binding LastActiveDisplay}" Width="140"/>
                <DataGridTextColumn Header="Expires"      Binding="{Binding ExpiresDisplay}"    Width="140"/>
                <DataGridTextColumn Header="IP"           Binding="{Binding IpAddress}"        Width="120"/>
                <DataGridTextColumn Header="Browser"      Binding="{Binding ShortUserAgent}"   Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   Margin="0,8,0,0"
                   Foreground="#555"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Revoke selected" Width="130" Height="28" Margin="0,0,8,0"
                    x:Name="RevokeButton" IsEnabled="False"
                    Click="RevokeButton_Click"/>
            <Button Content="Revoke all"      Width="100" Height="28" Margin="0,0,8,0"
                    Click="RevokeAllButton_Click"
                    Foreground="Crimson"/>
            <Button Content="Refresh"         Width="80"  Height="28"
                    Click="RefreshButton_Click"/>
            <Button Content="Close"           Width="80"  Height="28"
                    HorizontalAlignment="Right"
                    Margin="20,0,0,0"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
