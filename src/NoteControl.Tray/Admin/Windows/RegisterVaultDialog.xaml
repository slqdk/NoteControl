<Window x:Class="NoteControl.Tray.Admin.Windows.RegisterVaultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register existing vault"
        Width="600" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: intro text -->
            <RowDefinition Height="Auto"/>  <!-- 1: folder picker -->
            <RowDefinition Height="Auto"/>  <!-- 2: relative path preview -->
            <RowDefinition Height="Auto"/>  <!-- 3: scope display -->
            <RowDefinition Height="Auto"/>  <!-- 4: owner picker -->
            <RowDefinition Height="Auto"/>  <!-- 5: vault name -->
            <RowDefinition Height="Auto"/>  <!-- 6: error text -->
            <RowDefinition Height="*"/>     <!-- 7: spacer -->
            <RowDefinition Height="Auto"/>  <!-- 8: buttons -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   TextWrapping="Wrap" Margin="0,0,0,12"
                   Foreground="#444"
                   Text="Adopt an existing folder as a NoteControl vault. The folder must live somewhere under the data root (e.g. copied from a backup). The server creates .notesapp/ if missing and rebuilds the search index from the markdown on disk."/>

        <Label Grid.Row="1" Grid.Column="0" Content="Folder:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 x:Name="FolderBox"
                 Padding="6,4" Margin="0,4,8,4"
                 IsReadOnly="True"
                 Background="#F5F5F5"/>
        <Button Grid.Row="1" Grid.Column="2"
                Content="Browse..."
                Width="80" Height="28"
                Margin="0,4"
                Click="BrowseButton_Click"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Relative path:" VerticalAlignment="Top" Margin="0,4,0,0"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                   x:Name="RelativePathPreview"
                   Margin="6,8,6,0"
                   Foreground="#444"
                   FontFamily="Consolas"
                   TextWrapping="Wrap"
                   Text="(pick a folder)"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Scope:" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                   x:Name="ScopeDisplay"
                   Margin="6,4,0,4"
                   VerticalAlignment="Center"
                   Foreground="#444"
                   Text="(determined from folder path)"/>

        <!--
            Owner dropdown.

            For Personal scope, the path's username segment determines
            who must own the vault. We auto-set the dropdown to that
            user and lock it (no point letting admin choose if the path
            says users/alice/Plans, since the owner must be alice).

            For Shared scope the dropdown is editable; admin can pick
            any active user as owner. Non-admin users can't reach this
            dialog at all (the button is admin-only in VaultsWindow).
        -->
        <Label Grid.Row="4" Grid.Column="0" Content="Owner:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                  x:Name="OwnerCombo"
                  Margin="0,4" Padding="6,4"
                  SelectionChanged="OwnerCombo_SelectionChanged"/>

        <Label Grid.Row="5" Grid.Column="0" Content="Vault name:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="NameBox"
                 Margin="0,4" Padding="6,4"
                 ToolTip="Display name. Defaults to the folder name."/>

        <TextBlock Grid.Row="6" Grid.ColumnSpan="3"
                   x:Name="ErrorText"
                   Margin="0,8,0,0"
                   Foreground="Crimson"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    IsCancel="True" Click="CancelButton_Click"/>
            <Button Content="Register"
                    x:Name="RegisterButton"
                    Width="90" Height="28"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
