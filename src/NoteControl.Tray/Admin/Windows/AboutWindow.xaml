<Window x:Class="NoteControl.Tray.Admin.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteControl — About"
        Width="560" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="NoteControl"
                       FontSize="22" FontWeight="SemiBold"/>
            <TextBlock x:Name="TaglineText"
                       Foreground="#666"
                       Margin="0,4,0,0"
                       Text="Self-hosted multi-user notes app for Windows."/>
        </StackPanel>

        <!-- Version + update button row -->
        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock>
                    <Run Text="Version: " FontWeight="SemiBold"/>
                    <Run x:Name="VersionText"/>
                </TextBlock>
                <TextBlock x:Name="BuildDateText"
                           Foreground="#666"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>
            <!--
                Step 49: button now wired up. The click handler asks
                App to run a fresh update check; the user gets a
                MessageBox for "up to date"/error or the UpdateWindow
                for "update available". Disabled while the check is
                in flight to prevent double-clicks.
            -->
            <Button DockPanel.Dock="Right"
                    x:Name="CheckUpdatesButton"
                    Content="Check for updates"
                    Width="140" Height="28"
                    Click="CheckUpdates_Click"
                    ToolTip="Asks GitHub if a newer release is published."/>
        </DockPanel>

        <Separator Grid.Row="2" Margin="0,0,0,12"/>

        <!-- Build info -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Build &amp; environment" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server URL:" Foreground="#555"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ServerUrlText" TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Data root:" Foreground="#555" Margin="0,3,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DataRootText" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text=".NET runtime:" Foreground="#555" Margin="0,3,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DotNetText" Margin="0,3,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="OS:" Foreground="#555" Margin="0,3,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="OsText" Margin="0,3,0,0"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Tray PID:" Foreground="#555" Margin="0,3,0,0"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="PidText" Margin="0,3,0,0"/>
            </Grid>
        </StackPanel>

        <!-- Links -->
        <StackPanel Grid.Row="4" VerticalAlignment="Top">
            <TextBlock Text="Resources" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBlock Margin="0,0,0,3">
                <Hyperlink x:Name="SpecLink" Click="OpenLink_Click" Tag="docs/NoteControl-Spec.md">
                    Open the specification (docs/NoteControl-Spec.md)
                </Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,0,0,3">
                <Hyperlink x:Name="LogsLink" Click="OpenLogsFolder_Click">
                    Open server logs folder
                </Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,0,0,3">
                <Hyperlink x:Name="DataLink" Click="OpenDataFolder_Click">
                    Open data folder
                </Hyperlink>
            </TextBlock>

            <TextBlock x:Name="StatusText"
                       Foreground="#666"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Footer -->
        <DockPanel Grid.Row="5" Margin="0,12,0,0">
            <Button DockPanel.Dock="Left"
                    Content="Copy diagnostics"
                    Width="140" Height="28"
                    Click="CopyDiagnostics_Click"
                    ToolTip="Copies version + build info + paths to the clipboard. Paste when reporting an issue."/>
            <Button DockPanel.Dock="Right"
                    Content="Close" Width="80" Height="28"
                    IsCancel="True"
                    Click="CloseButton_Click"/>
        </DockPanel>
    </Grid>
</Window>
