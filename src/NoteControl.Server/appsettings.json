{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\ProgramData\\NoteControl\\logs\\notecontrol-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Storage": {
    "DataRoot": "C:\\ProgramData\\NoteControl\\NotesData"
  },
  "Security": {
    "RequireHttps": true
  },
  "Auth": {
    "SessionCookieName": "nc_sid",
    "CsrfCookieName": "nc_csrf",
    "CsrfHeaderName": "X-CSRF-Token",
    "IdleTimeoutMinutes": 720,
    "AbsoluteTimeoutMinutes": 10080,
    "RequireSecureCookies": false,
    "MinimumPasswordLength": 12,
    "CheckPasswordAgainstHibp": true,
    "LoginAttemptsPerIpPerMinute": 5,
    "LoginAttemptsPerAccountPerHour": 10,
    "AccountLockoutMinutes": 30,
    "BootstrapAdmin": {
      "Username": "admin",
      "Email": "admin@localhost",
      "Password": null
    }
  },
  "Network": {
    "Port": 8080,
    "ExposeOnLan": false,
    "PublicUrl": ""
  },
  "Backup": {
    "Enabled": false,
    "TargetPath": "",
    "DailyTime": "03:30",
    "RetainDailyCount": 7,
    "RetainWeeklyCount": 4
  },
  "Logging": {
    "MinimumLevel": "Information",
    "RetainDays": 30
  }
}
